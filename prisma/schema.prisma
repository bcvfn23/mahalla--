datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  admin
  uchastkavoy
  raisi
  yetakchi
  read_only
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum Gender {
  MALE
  FEMALE
}

// User model for role-based access control
model User {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String
  name         String
  avatar       String?
  role         Role       @default(read_only)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
  sessions     Session[]
}

// Session model for token refresh rotations
model Session {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken      String   @unique
  userAgent         String?
  ipAddress         String?
  deviceFingerprint String?
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// Geography and regions
model Region {
  id        String     @id @default(uuid())
  nameUz    String     @unique
  nameRu    String     @unique
  districts District[]
}

model District {
  id       String    @id @default(uuid())
  nameUz   String
  nameRu   String
  regionId String
  region   Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  mahallas Mahalla[]

  @@index([regionId])
}

model Mahalla {
  id         String         @id @default(uuid())
  nameUz     String
  nameRu     String
  districtId String
  district   District       @relation(fields: [districtId], references: [id], onDelete: Cascade)
  profiles   YouthProfile[]

  @@index([districtId])
}

// Youth profile database
model YouthProfile {
  id           String             @id @default(uuid())
  ism          String
  familiya     String
  jshshir      String             @unique
  pasport      String             @unique
  yil          String
  jins         Gender
  telefon      String
  davomat      String             @default("100")
  xavf         RiskLevel          @default(LOW)
  maktab       String?            // Employment/Activity description
  izoh         String?
  mahallaId    String
  mahalla      Mahalla            @relation(fields: [mahallaId], references: [id])
  attendance   Attendance[]
  employment   Employment?
  socialAid    SocialAid[]
  incidents    Incident[]
  appeals      Appeal[]
  participants EventParticipant[]
  jointReports JointReport[]

  // Concurrency & Soft Delete
  version      Int                @default(1)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?          // Soft Delete

  @@index([familiya, ism])
  @@index([mahallaId])
  @@index([xavf])
}

model Attendance {
  id        String       @id @default(uuid())
  profileId String
  profile   YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date      DateTime
  present   Boolean
  reason    String?

  @@index([profileId])
}

// Employment details (replaces local bandlikList)
model Employment {
  id         String       @id @default(uuid())
  profileId  String       @unique
  profile    YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profession String
  status     String       // "ishsiz", "band", "o'qishda"
  
  // Concurrency & Soft Delete
  version    Int          @default(1)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  @@index([profileId])
}

// Social Aid details (replaces local yordamList)
model SocialAid {
  id           String       @id @default(uuid())
  profileId    String
  profile      YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  notebookType String       // "temir", "ayol", "yoshlar"
  helpType     String
  status       String       @default("kutmoqda") // "kutmoqda", "hal_etildi"
  
  // Concurrency & Soft Delete
  version      Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([profileId])
}

// Incident management database
model Incident {
  id         String        @id @default(uuid())
  profileId  String?
  profile    YouthProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  name       String
  typeUz     String
  typeRu     String
  date       String
  locationUz String
  locationRu String
  status     String        @default("jarayonda") // yopilgan, jarayonda
  severity   String        @default("low")       // low, medium, high
  
  // Concurrency & Soft Delete
  version    Int           @default(1)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?     // Soft Delete

  @@index([status])
  @@index([createdAt])
}

// Appeals database
model Appeal {
  id                String        @id @default(uuid())
  profileId         String?
  profile           YouthProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  fullName          String
  type              String
  text              String
  date              String
  status            String        @default("yangi")     // hal etilgan, kutilmoqda, yangi
  predictedCategory String?
  
  // Concurrency & Soft Delete
  version           Int           @default(1)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?     // Soft Delete

  @@index([createdAt])
}

// AuditLog model
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   Json
  stateDiff Json?    // Stores { before: Json, after: Json } for state audit
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

// Brute-force Login Protection tracking per Username + IP hash
model LoginAttempt {
  id             String    @id @default(uuid())
  username       String
  ipAddress      String
  attempts       Int       @default(0)
  lockoutCount   Int       @default(0)
  lockoutExpires DateTime?
  updatedAt      DateTime  @updatedAt

  @@unique([username, ipAddress])
  @@index([username, ipAddress])
}

model IpLockout {
  id             String    @id @default(uuid())
  ipAddress      String    @unique
  attempts       Int       @default(0)
  lockoutExpires DateTime?
  updatedAt      DateTime  @updatedAt

  @@index([ipAddress])
}

// Transactional Outbox
model EventOutbox {
  id           String    @id @default(uuid())
  eventType    String
  eventVersion Int       @default(1)
  payload      Json
  processedAt  DateTime?
  error        String?
  retryCount   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([processedAt, retryCount])
}

// Idempotent Consumers log
model IdempotentConsumer {
  id           String   @id // eventId
  consumerName String
  processedAt  DateTime @default(now())

  @@unique([id, consumerName])
}

// Competitions and Events (replaces local eventsList)
model Event {
  id           String             @id @default(uuid())
  titleUz      String
  titleRu      String
  date         String
  status       String             @default("kutilmoqda") // "kutilmoqda", "jarayonda", "yakunlangan"
  participants EventParticipant[]
  
  // Concurrency & Soft Delete
  version      Int                @default(1)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?

  @@index([status])
}

model EventParticipant {
  id        String       @id @default(uuid())
  eventId   String
  event     Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  profileId String
  profile   YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([eventId, profileId])
}

// Joint patrol reports (replaces local jointReports)
model JointReport {
  id            String        @id @default(uuid())
  timestamp     String
  inspectorName String
  leaderName    String
  profileId     String?
  profile       YouthProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  mahalla       String
  descriptionUz String
  descriptionRu String
  createdAt     DateTime      @default(now())

  @@index([profileId])
}

// Custom patrol routes (replaces local customPatrolRoutes)
model PatrolRoute {
  id        String   @id @default(uuid())
  nameUz    String
  nameRu    String
  points    Json     // Coordinate arrays
  createdAt DateTime @default(now())
}

// Kanban Task list model
model Task {
  id        String   @id @default(uuid())
  title     String
  desc      String
  status    String   // "todo", "in_progress", "done"
  priority  String   // "low", "medium", "high"
  type      String   // "standard", "leader"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
